# Anthropic API 키
ANTHROPIC_API_KEY=sk-ant-api03-...

# Google Sheets 스프레드시트 ID (URL에서 확인)
# 예: https://docs.google.com/spreadsheets/d/<여기>/edit
GOOGLE_SHEETS_ID=your_spreadsheet_id_here

# Google 서비스 계정 JSON 파일 경로 (로컬)
GOOGLE_SERVICE_ACCOUNT_FILE=service_account.json

# Google 서비스 계정 JSON 내용 전체 (Railway 클라우드용)
# Railway 환경변수에 service_account.json 파일 내용을 그대로 붙여넣으세요
# GOOGLE_SERVICE_ACCOUNT_JSON={"type":"service_account",...}

# PostgreSQL 연결 URL (Short-term Memory)
# 로컬: 비워두면 RAM 기반 MemorySaver로 자동 전환됩니다
# Railway: PostgreSQL 플러그인 추가 시 자동 설정됩니다
# DATABASE_URL=postgresql://user:password@host:5432/dbname

# Mem0 API 키 (Long-term Memory)
# https://mem0.ai 에서 회원가입 후 발급
# 비워두면 장기 기억 기능 없이 동작합니다
# MEM0_API_KEY=m0-...
